#!/bin/bash
#
# edit — Edit an existing image via the OpenAI image edits API.
#
# Usage:
#   ./edit <image_file> "<prompt>"
#
# Prerequisites:
#   - An OpenAI API key stored in a file called "openaikey" in the same
#     directory as this script.
#   - curl, jq, and base64 must be available on your PATH.
#
# The script uploads the given image along with a text prompt to
# gpt-image-1.5 and saves the edited result as a timestamped PNG
# in the current directory (e.g. 20260303-141500-out.png).
#
# Examples:
#   ./edit building.png "remove the chimney and add a skylight"
#   ./edit tree.png "change the leaves to autumn colors"
#
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
OPENAI_KEY=$(cat "$(dirname "$0")/openaikey")

RESPONSE=$(curl -s -D >(grep -i x-request-id >&2) \
  -X POST "https://api.openai.com/v1/images/edits" \
  -H "Authorization: Bearer ${OPENAI_KEY}" \
  -F "model=gpt-image-1.5" \
  -F "quality=high" \
  -F "image[]=@$1" \
  -F "prompt=$2")

if echo "$RESPONSE" | jq -e '.data[0].b64_json' > /dev/null 2>&1; then
  echo "$RESPONSE" | jq -r '.data[0].b64_json' | base64 --decode > "${TIMESTAMP}-out.png"
  echo "Saved ${TIMESTAMP}-out.png"
else
  echo "API error:" >&2
  echo "$RESPONSE" | jq . >&2
  exit 1
fi

