#!/bin/bash
#
# edit2 — Edit with TWO reference images via the OpenAI image edits API.
#
# Usage:
#   ./edit2 <image1> <image2> "<prompt>"
#
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
OPENAI_KEY=$(cat "$(dirname "$0")/openaikey")

RESPONSE=$(curl -s -D >(grep -i x-request-id >&2) \
  -X POST "https://api.openai.com/v1/images/edits" \
  -H "Authorization: Bearer ${OPENAI_KEY}" \
  -F "model=gpt-image-1.5" \
  -F "quality=high" \
  -F "image[]=@$1" \
  -F "image[]=@$2" \
  -F "prompt=$3")

if echo "$RESPONSE" | jq -e '.data[0].b64_json' > /dev/null 2>&1; then
  echo "$RESPONSE" | jq -r '.data[0].b64_json' | base64 --decode > "${TIMESTAMP}-out.png"
  echo "Saved ${TIMESTAMP}-out.png"
else
  echo "API error:" >&2
  echo "$RESPONSE" | jq . >&2
  exit 1
fi
